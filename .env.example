# =====================================================
# NexConflict Environment Configuration
# Copy to .env and configure for your environment
# =====================================================

# ==================== DATABASE ====================
POSTGRES_USER=nexconflict
POSTGRES_PASSWORD=nexconflict123
POSTGRES_DB=nexconflict_db

# ==================== JWT ====================
# Generate a secure random string (at least 256 bits / 32 bytes)
# Example: openssl rand -base64 32
JWT_SECRET=your_jwt_secret_here_must_be_at_least_256_bits_or_32_characters_long
JWT_EXPIRATION=86400000

# ==================== TMDB API ====================
# Get your API key from: https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_tmdb_api_key_here
